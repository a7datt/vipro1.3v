# ============================================================
#  .env.example — نسخة آمنة بدون بيانات حقيقية
#  انسخ هذا الملف إلى .env واملأ القيم الحقيقية
#  تأكد أن .env موجود في .gitignore ولا يُرفع على GitHub أبداً
# ============================================================

# ── Security (مطلوب — ولّد قيم عشوائية قوية) ──────────────
# استخدم: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_RANDOM_64_BYTE_HEX"
ADMIN_JWT_SECRET="CHANGE_ME_USE_DIFFERENT_RANDOM_64_BYTE_HEX"

# ── Frontend URL (للـ CORS) ────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# ── Telegram Bots ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN="YOUR_ADMIN_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_ADMIN_CHAT_ID"
TELEGRAM_USER_BOT_TOKEN="YOUR_USER_BOT_TOKEN"

# ── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY="YOUR_RESEND_API_KEY"
FROM_EMAIL="noreply@yourdomain.com"
STORE_NAME="VIPro"

# ── Image Upload (ImgBB) ───────────────────────────────────
IMGBB_API_KEY="YOUR_IMGBB_API_KEY"
VITE_IMGBB_API_KEY="YOUR_IMGBB_API_KEY"

# ── Web Push VAPID ─────────────────────────────────────────
# توليد: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"

# ── Ahminix API ────────────────────────────────────────────
AHMINIX_API_TOKEN="YOUR_AHMINIX_TOKEN"

# ── APISyria ───────────────────────────────────────────────
APISYRIA_API_KEY="YOUR_APISYRIA_KEY"
